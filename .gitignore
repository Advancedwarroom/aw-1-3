# Godot 4+ specific ignores
.godot/
/android/

# C# / .NET build output
bin/
obj/

# User-specific IDE files
*.csproj.user
*.sln.user
*.userprefs

# VS Code settings (optional — remove if you want to share launch.json)
.vscode/

# Cache / temp
*.lscache
*.tmp
*.temp

# Godot editor binaries — DO NOT commit the engine itself
Godot_v4*.exe
Godot_v4*.x86_64
Godot_v4*.app

# Movie / video recordings generated by the editor
MovieWriters/

# Local export artifacts (built games)
*.exe
*.pck
*.apk
*.ipa
*.x86_64
*.zip
*.tar.gz

# OS junk
.DS_Store
Thumbs.db
desktop.ini
